# =============================================
# Biến môi trường cần thiết để chạy ứng dụng
# Copy file này thành .env và điền giá trị
# =============================================

NODE_ENV=development
PORT=3000

# Database MySQL (ví dụ: PlanetScale, Railway, Aiven)
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://user:password@host:3306/hopnheem

# JWT secret để ký session cookie (chuỗi ngẫu nhiên dài)
JWT_SECRET=your-super-secret-key-change-this

# OAuth server (nếu dùng Manus OAuth)
OAUTH_SERVER_URL=https://oauth.example.com
VITE_OAUTH_PORTAL_URL=https://oauth.example.com

# App ID từ OAuth provider
VITE_APP_ID=your-app-id

# OpenID của owner (admin đầu tiên)
OWNER_OPEN_ID=your-open-id

# Tuỳ chọn: Forge API (AI features)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
